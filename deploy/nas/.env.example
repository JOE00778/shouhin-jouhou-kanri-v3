# =====================================================================
# 一元管理系统 V2.3 · NAS 部署配置
# 复制为 .env 后填入真实值（明天 Boss 给信息时一次填完）
# =====================================================================

# ────────────────────── 1. NAS 路径 ──────────────────────
# Postgres 数据 / 上传文件落盘路径（NAS volume，要持久）
DATA_DIR=/volume1/docker/cms-v230

# ────────────────────── 2. Postgres ──────────────────────
POSTGRES_DB=cms
POSTGRES_USER=cms
# 强密码！（建议 32 位随机串，建库后不再改）
POSTGRES_PASSWORD=__CHANGE_ME_TO_STRONG_RANDOM_PASSWORD__

# ────────────────────── 3. 双角色登录 ──────────────────────
ADMIN_USERNAME=JO043
ADMIN_PASSWORD=smikie043
GUEST_USERNAME=smikiejapan
GUEST_PASSWORD=smikie123

# ────────────────────── 4. 飞书 H5 应用 ──────────────────────
# 明天 Boss 在飞书开放平台创建自建应用后填
# https://open.feishu.cn/app
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OAuth 回调（应填飞书侧重定向用的 URL，跟下面 PUBLIC_DOMAIN 一致）
LARK_REDIRECT_URI=https://cms.smikie.xx/auth/lark/callback

# ────────────────────── 5. Cloudflare Tunnel ──────────────────────
# 在 Cloudflare Zero Trust → Networks → Tunnels 创建后获取
# 配置时把 service = http://streamlit:8501，hostname = ${PUBLIC_DOMAIN}
CLOUDFLARE_TUNNEL_TOKEN=eyJ___CHANGE_ME___xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_DOMAIN=cms.smikie.xx
