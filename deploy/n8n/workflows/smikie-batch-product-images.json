              "value": "=[\n  {\n    \"jan\": \"4901111310490\",\n    \"商品名\": \"AGF ブレンディ カフェラトリー スティック 濃厚キャラメルマキアート 7本\",\n    \"メーカー\": \"AGF\",\n    \"カテゴリ\": \"インスタントコーヒー / スティック\",\n    \"卖点\": \"濃厚カラメル、ミルク感たっぷり、オフィスで手軽に\",\n    \"风格\": \"日系カフェ、温かみ、自然光\"\n  },\n  {\n    \"jan\": \"4902430714083\",\n    \"商品名\": \"P&G アリエール ジェルボール 4D 抗菌\",\n    \"メーカー\": \"P&G\",\n    \"カテゴリ\": \"洗濯洗剤 / ジェルボール\",\n    \"卖点\": \"4層構造、抗菌、汚れ落ち\",\n    \"风格\": \"清潔感、白基調、ミニマル\"\n  },\n  {\n    \"jan\": \"4901301400000\",\n    \"商品名\": \"花王 メリット シャンプー リンスのいらない\",\n    \"メーカー\": \"花王\",\n    \"カテゴリ\": \"ヘアケア / シャンプー\",\n    \"卖点\": \"地肌すっきり、家族で使える、フケかゆみ防止\",\n    \"风格\": \"バスルーム、ナチュラル、生活感\"\n  }\n]",
