# Smikie N8N · 部署配置（由 install.ps1 自动生成；手动编辑请保留行尾换行）
# ============================================================
# 必填 5 项 + 可选 4 项

# ----- 公网入口 -----
# Cloudflare 注册的子域名（在 CF Dashboard → Tunnels → Public Hostname 配同名）
N8N_HOST=n8n.smikie-cms.cc

# Cloudflare Tunnel Token（在 Cloudflare Zero Trust → Networks → Tunnels → 选 Tunnel → Connectors 复制）
CLOUDFLARE_TUNNEL_TOKEN=

# ----- N8N 内置守门 -----
# 第一层守门（CF Access 邮箱白名单是第二层）
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# N8N 凭证加密 keychain（32 字符随机串；安装后不要修改否则所有保存的凭证失效）
N8N_ENCRYPTION_KEY=

# ----- CMS 集成 -----
# CMS 基础 URL（v2.0 workflow 用其拼接 /api/sku/master + /api/automation/xlsx-upload）
CMS_BASE_URL=https://smikie-cms.cc

# CMS 回调地址（workflow 跑完后写回结果给 CMS）
CMS_CALLBACK_URL=https://smikie-cms.cc/api/automation/callback

# ----- 飞书通知（可选，留空则跳过） -----
# 飞书群机器人 Webhook URL（在飞书群 → 设置 → 群机器人 → 添加自定义机器人）
LARK_WEBHOOK_URL=

# 飞书机器人签名校验 Secret（在机器人安全设置启用「签名校验」时填）
# 留空 = 不启用签名（机器人必须用「自定义关键词」防滥发）
# 填了 = N8N workflow 计算 HMAC-SHA256 签名校验
LARK_BOT_SIGN_SECRET=

# ----- 飞书 OpenAPI（改廃监控 stock-monitor 写飞书表格用） -----
# 飞书自建应用 → 凭证与基础信息 → App ID / App Secret
# 留空则改廃监控仍能跑（写本地 reports/），但不会同步到飞书表格
LARK_APP_ID=
LARK_APP_SECRET=

# ----- CMS 队列接口（Shopee 7x24 cron workflow 用） -----
# N8N 每 4 小时拉一次该 URL 看是否有 pending 任务
CMS_QUEUE_URL=https://smikie-cms.cc/api/automation/queue?module=shopee_mass_upload&status=pending

# ----- Shopee Open API（v2.2 workflow B3.5 category_recommend + B5c 真上架用） -----
# Partner ID/Key 在 Shopee Open Platform 创建应用拿（审核 3-7 天）
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Shopee API base（生产 partner.shopeemobile.com / 沙盒 partner.test-stable.shopeemobile.com）
SHOPEE_API_BASE=https://partner.shopeemobile.com

# 各国 shop_id (JSON dict，逐国 OAuth 走完拿到)
# 示例: {"TW":"123456","PH":"234567","MY":"345678","SG":"...","TH":"...","VN":"...","ID":"..."}
# 不填某国 = 该国 category_recommend 跳过（其他国仍跑）
SHOPEE_SHOP_IDS={}

# 各国 access_token (JSON dict，access_token 有效期 4 小时，需 cron 自动 refresh)
# 示例: {"TW":"eyJ...","PH":"eyJ...","..."}
# 留空 = stub 模式，整个 B3.5 节点 skip，XLSX category_id 列空
SHOPEE_ACCESS_TOKENS={}

# ============================================================
# LLM / 图像模型 API Key（国产，本地化合规：国内云 + 承诺不训练用户数据）
# 数据安全策略：SKU 价格/库存/客户名严禁进 prompt；仅商品文本/图片走云
# ============================================================

# ----- DeepSeek（文本：标题/详情生成、7 国翻译） -----
# https://platform.deepseek.com/ → API Keys
DEEPSEEK_API_KEY=

# ----- 火山方舟（文本：DeepSeek-V3.2 / 豆包；图像：Seedream/豆包 Vision） -----
# https://console.volcengine.com/ark → API Key
VOLC_ARK_API_KEY=

# 火山方舟「文本」模型 endpoint ID（shopee-mass-upload v2.0 用其生成 SPU 内容 + 7 国翻译）
# 推荐 deepseek-v3-2-251201（DeepSeek-V3.2）或 ep-xxx 自定义 endpoint
# 留空 = 用默认 deepseek-v3-2-251201
VOLC_ARK_TEXT_MODEL=deepseek-v3-2-251201

# ----- 备用国产 LLM（可选，工作流灰度切换时启用） -----
# 阿里通义千问 https://dashscope.console.aliyun.com/
QWEN_API_KEY=
# 智谱 GLM https://open.bigmodel.cn/
ZHIPU_API_KEY=

# ----- N8N UI 语言（可选） -----
# zh-CN (简体中文 ~60% 翻译) / ja (日文 ~70% 翻译) / en (英文，默认)
# 留空 = 英文。翻译覆盖率不是 100%，节点名/错误信息可能仍是英文。
N8N_DEFAULT_LOCALE=

# ----- 商品图处理 sidecar（image-processor 容器） -----
# Windows D 盘的图片根目录。docker-compose 会把它挂到容器内 /data/whitebg
# 首跑会自动建子目录：raw/ upscaled/ branded/ spu/
# 路径写法：Win 用 D:/Smikie-Images（正斜杠），Linux/Mac 用绝对路径
WHITEBG_HOST_PATH=D:/Smikie-Images

# ----- CMS API sidecar（cms-api 容器） -----
# cms-api 通过跨 stack network smikie_shared 直连 cms_postgres 容器
# DATABASE_URL 留空 = 用 docker-compose 默认值 postgresql://cms:${POSTGRES_PASSWORD}@cms_postgres:5432/cms
# CMS_DATABASE_URL 让你完整覆盖（连别处的 Postgres、或测试场景）
CMS_DATABASE_URL=

# CMS V2.3 部署用的 Postgres 密码（跟 deploy/windows/.env 的 POSTGRES_PASSWORD 必须一致！）
# 否则 cms-api 连 cms_postgres 会 authentication failed
POSTGRES_PASSWORD=

# XLSX dry-run 产出目录（N8N B5b.2 节点上传后落这里；rw）
# 资源管理器可直接访问看；默认放在 Smikie-Images 同根方便统一备份
CMS_OUTPUTS_HOST_PATH=D:/Smikie-Images/automation_outputs
