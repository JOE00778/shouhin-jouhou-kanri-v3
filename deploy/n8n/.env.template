# Smikie N8N · 部署配置（由 install.ps1 自动生成；手动编辑请保留行尾换行）
# ============================================================
# 必填 5 项 + 可选 4 项

# ----- 公网入口 -----
# Cloudflare 注册的子域名（在 CF Dashboard → Tunnels → Public Hostname 配同名）
N8N_HOST=n8n.smikie-cms.cc

# Cloudflare Tunnel Token（在 Cloudflare Zero Trust → Networks → Tunnels → 选 Tunnel → Connectors 复制）
CLOUDFLARE_TUNNEL_TOKEN=

# ----- N8N 内置守门 -----
# 第一层守门（CF Access 邮箱白名单是第二层）
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# N8N 凭证加密 keychain（32 字符随机串；安装后不要修改否则所有保存的凭证失效）
N8N_ENCRYPTION_KEY=

# ----- CMS 集成 -----
# CMS 回调地址（workflow 跑完后写回结果给 CMS）
CMS_CALLBACK_URL=https://smikie-cms.cc/api/automation/callback

# ----- 飞书通知（可选，留空则跳过） -----
# 飞书群机器人 Webhook URL（在飞书群 → 设置 → 群机器人 → 添加自定义机器人）
LARK_WEBHOOK_URL=

# ----- 飞书 OpenAPI（改廃监控 stock-monitor 写飞书表格用） -----
# 飞书自建应用 → 凭证与基础信息 → App ID / App Secret
# 留空则改廃监控仍能跑（写本地 reports/），但不会同步到飞书表格
LARK_APP_ID=
LARK_APP_SECRET=

# ----- CMS 队列接口（Shopee 7x24 cron workflow 用） -----
# N8N 每 4 小时拉一次该 URL 看是否有 pending 任务
CMS_QUEUE_URL=https://smikie-cms.cc/api/automation/queue?module=shopee_mass_upload&status=pending

# ----- Shopee Open API（可选，配 Shopee 上架 workflow 时填） -----
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# ----- LLM API Key（可选，jan-extract workflow 用） -----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
