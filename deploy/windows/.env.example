# =====================================================================
# 一元管理系统 V2.3 · Windows 部署配置
# 复制为 .env 后填入真实值
# =====================================================================

# ────────────────────── 1. 数据路径（Windows） ──────────────────────
# 推荐用非系统盘（D 盘）减少 SSD 写入冲突
# 注意：Windows 路径反斜杠在 docker-compose 里要用 / 或 \\
DATA_DIR=D:/cms-v230/data

# ────────────────────── 2. Postgres ──────────────────────
POSTGRES_DB=cms
POSTGRES_USER=cms
POSTGRES_PASSWORD=__CHANGE_ME_TO_STRONG_RANDOM_PASSWORD__

# ────────────────────── 3. 双角色登录 ──────────────────────
ADMIN_USERNAME=JO043
ADMIN_PASSWORD=smikie043
GUEST_USERNAME=smikiejapan
GUEST_PASSWORD=smikie123

# ────────────────────── 4. 飞书 H5 应用 ──────────────────────
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_REDIRECT_URI=https://cms.smikie.xx
# 飞书登录后自动判定 admin 角色的邮箱白名单（逗号分隔）
ADMIN_LARK_EMAILS=lixin@mitsukin.info

# ────────────────────── 5. Cloudflare Tunnel ──────────────────────
CLOUDFLARE_TUNNEL_TOKEN=eyJ___CHANGE_ME___xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_DOMAIN=cms.smikie.xx

# ────────────────────── 5b. pgweb（DB 可视化, http://localhost:8081）──────────────────────
# 仅绑 127.0.0.1；留空 = 不加认证（笔记本本机访问足够）。想再加一层简易口令就填下面两行：
PGWEB_AUTH_USER=
PGWEB_AUTH_PASS=

# ────────────────────── 6. LinkStation LS210DC 备份 ──────────────────────
# 用 SMB 挂载 LS210DC 做 Postgres dump 备份（影刀友好，凌晨 3 点跑）
LS210DC_SMB_PATH=\\LS210DC\backup\cms-v230
LS210DC_USER=admin
LS210DC_PASSWORD=
